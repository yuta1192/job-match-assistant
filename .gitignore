# monorepo 共通の除外設定

# 環境変数（秘密情報・ローカル設定）
.env
*.env.local

# OS
.DS_Store

# --- backend (Rails) ---
backend/tmp/
backend/log/
backend/storage/
backend/.bundle/
/backend/vendor/bundle
# Rails の本番暗号鍵。絶対にコミットしない（credentials.yml.enc は暗号化済みなのでコミット可）
backend/config/master.key

# --- frontend (Next.js) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/next-env.d.ts
npm-debug.log*

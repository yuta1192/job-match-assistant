# docker compose 用の環境変数サンプル。
# `cp .env.example .env` してから `docker compose up` する（.env は git 管理外）。

# PostgreSQL コンテナの認証情報（backend もこの値で接続する）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# LLM(Anthropic) 連携。未設定でもスタブ応答で動作する（Phase 5）。
# 実際に分析/返信生成を行うにはキーを設定する。
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5   # 既定。sonnet/opus へ変更可

